{
  "presets": [
    [
      "@babel/env",
      {
        "modules": false,
        "shippedProposals": true
      }
    ]
  ],
  "babelrcRoots": [".", "./packages/*"],
  "sourceType": "unambiguous",
  "env": {
    "test": {
      "presets": [
        ["@babel/env", { "shippedProposals": true }],
        ["@babel/preset-typescript", { "isTSX": true, "allExtensions": true }]
      ],
      "plugins": [
        ["@babel/plugin-transform-react-jsx", { "runtime": "automatic" }]
      ]
    }
  }
}
