{
  "transform": {
    "^.+\\.(j|t)sx?$": ["babel-jest", { "rootMode": "upward" }]
  },
  "testEnvironment": "jsdom",
  "moduleNameMapper": {
    "\\.(css|styl)$": "identity-obj-proxy"
  },
  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    "test/runtime/react/"
  ],
  "setupFiles": ["<rootDir>/test/runtime/react-native/setup.js"],
  "testTimeout": 10000
}
