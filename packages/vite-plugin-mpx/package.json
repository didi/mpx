{
  "name": "@mpxjs/vite-plugin-mpx",
  "version": "2.6.102",
  "description": "Vite plugin of mpx convert to web",
  "main": "dist/index.js",
  "types": "temp/index.d.ts",
  "author": "mater1996 <bxh8640@gmail.com>",
  "license": "MIT",
  "files": [
    "dist",
    "temp",
    "src"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git@github.com:mater1996/vite-plugin-mpx.git"
  },
  "keywords": [
    "vite",
    "mpx"
  ],
  "scripts": {
    "dev": "tsc -p . -w --incremental",
    "build": "rimraf dist && npm run build-bundle && npm run build-types",
    "build-bundle": "node ./scripts/build.js",
    "build-types": "tsc -p . --emitDeclarationOnly --outDir temp",
    "lint": "npx eslint --fix . --ext .ts"
  },
  "devDependencies": {
    "@commitlint/cli": "^15.0.0",
    "@commitlint/config-conventional": "^15.0.0",
    "@mpxjs/webpack-plugin": "^2.6.102",
    "@types/debug": "^4.1.7",
    "@types/hash-sum": "^1.0.0",
    "@types/node": "^16.11.6",
    "@types/qs": "^6.9.7",
    "@typescript-eslint/eslint-plugin": "^4.26.1",
    "@typescript-eslint/parser": "^4.26.1",
    "esbuild": "^0.14.2",
    "execa": "^5.1.1",
    "rollup": "^2.60.2",
    "typescript": "^4.3.2",
    "vite": "^2.7.0"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^21.0.1",
    "@rollup/plugin-replace": "^3.0.0",
    "@rollup/pluginutils": "^4.1.1",
    "debug": "^4.3.2",
    "hash-sum": "^2.0.0",
    "json5": "^2.2.0",
    "qs": "^6.10.1",
    "rollup-plugin-polyfill-node": "^0.7.0",
    "slash": "^3.0.0",
    "vite-plugin-vue2": "^1.9.0",
    "vue-template-compiler": "^2.6.14"
  },
  "peerDependencies": {
    "@mpxjs/webpack-plugin": "^2.6.102",
    "rollup": "^2.60.2",
    "vite": "^2.7.0"
  }
}
