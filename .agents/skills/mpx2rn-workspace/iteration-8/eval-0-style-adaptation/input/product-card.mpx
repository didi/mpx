<template>
  <view class="product-card">
    <view class="card-header">
      <image class="card-avatar" src="{{info.avatar}}" mode="aspectFill"></image>
      <view class="card-title-wrap">
        <text class="card-title">{{info.title}}</text>
        <text class="card-subtitle">{{info.subtitle}}</text>
      </view>
    </view>
    <view class="card-body">
      <text class="card-desc">{{info.description}}</text>
      <view class="card-tags">
        <text class="tag" wx:for="{{info.tags}}" wx:key="*this" wx:class="{{{'tag-highlight': item === info.tags[0]}}}">{{item}}</text>
      </view>
    </view>
    <view class="card-footer">
      <text class="price">{{info.price}}</text>
      <view class="btn-buy" bindtap="onBuy">
        <text class="btn-text">立即购买</text>
      </view>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    info: { type: Object, value: {} }
  },
  methods: {
    onBuy () {
      this.triggerEvent('buy', { id: this.info.id })
    }
  }
})
</script>

