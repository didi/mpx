<template>
  <view class="product-card">
    <!-- RN 不支持 ::before 伪元素，用真实节点替代 -->
    <view class="card-top-bar"></view>
    <view class="card-header">
      <image class="card-avatar" src="{{info.avatar}}" mode="aspectFill"></image>
      <view class="card-title-wrap">
        <text class="card-title" numberOfLines@ios|android|harmony="{{1}}">{{info.title}}</text>
        <text class="card-subtitle">{{info.subtitle}}</text>
      </view>
    </view>
    <view class="card-body">
      <text class="card-desc" numberOfLines@ios|android|harmony="{{1}}">{{info.description}}</text>
      <view class="card-tags">
        <text
          class="tag"
          wx:for="{{info.tags}}"
          wx:key="*this"
          wx:class="{{{'tag-highlight': item === info.tags[0]}}}"
        >{{item}}</text>
      </view>
    </view>
    <view class="card-footer">
      <text class="price">{{info.price}}</text>
      <view class="btn-buy" bindtap="onBuy" hover-class="btn-buy-hover" hover-stay-time="{{100}}">
        <text class="btn-text">立即购买</text>
      </view>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    info: { type: Object, value: {} }
  },
  methods: {
    onBuy () {
      this.triggerEvent('buy', { id: this.info.id })
    }
  }
})
</script>

<style lang="less">
.product-card {
  margin: 16rpx;
  background: #fff;
  border-radius: 12rpx;
  overflow: hidden;
  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
  /* @mpx-endif */
}

/* 顶部渐变色条（替代 ::before 伪元素实现） */
.card-top-bar {
  height: 4rpx;
  background: linear-gradient(to right, #1677ff, #69c0ff);
}

.card-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding: 24rpx;
  border-bottom-style: solid;
  border-bottom-color: #f0f0f0;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-bottom-width: hairlineWidth;
  /* @mpx-else */
  border-bottom-width: 1rpx;
  /* @mpx-endif */
}

.card-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.card-title-wrap {
  flex: 1;
  overflow: hidden;
  margin-left: 16rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  /* @mpx-endif */
}

.card-subtitle {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.card-body {
  padding: 24rpx;
}

.card-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  /* @mpx-endif */
}

.card-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 16rpx;
}

.tag {
  font-size: 22rpx;
  color: #1677ff;
  background: rgba(22, 119, 255, 0.08);
  padding-top: 4rpx;
  padding-bottom: 4rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  border-radius: 4rpx;
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.tag-highlight {
  background: rgba(255, 77, 79, 0.08);
  color: #ff4d4f;
}

.card-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  padding-top: 20rpx;
  padding-bottom: 20rpx;
  padding-left: 24rpx;
  padding-right: 24rpx;
  border-top-style: solid;
  border-top-color: #f0f0f0;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-top-width: hairlineWidth;
  /* @mpx-else */
  border-top-width: 1rpx;
  /* @mpx-endif */
}

.price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4d4f;
}

.btn-buy {
  padding-top: 12rpx;
  padding-bottom: 12rpx;
  padding-left: 32rpx;
  padding-right: 32rpx;
  background: #1677ff;
  border-radius: 8rpx;
}

.btn-buy-hover {
  opacity: 0.7;
}

.btn-text {
  font-size: 26rpx;
  color: #fff;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {}
}
