<template>
  <view class="profile-page">
    <view class="user-section">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-id">ID: {{userInfo.userId}}</text>
      </view>
    </view>
    <view class="menu-list">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap(item)">
        <text class="menu-label">{{item.label}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="action-section">
      <view class="btn-logout" bindtap="logout">
        <text class="btn-text">退出登录</text>
      </view>
    </view>
  </view>
</template>

<script>
import mpx, { createPage } from '@mpxjs/core'

const isRN = __mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony'

const pageOptions = {
  data: {
    userInfo: {},
    menuItems: [
      { id: 1, label: '我的订单', path: '/pages/orders' },
      { id: 2, label: '收货地址', path: '/pages/address' },
      { id: 3, label: '账户设置', path: '/pages/settings' },
      { id: 4, label: '关于我们', path: '/pages/about' }
    ],
    locationInfo: null
  },
  onLoad () {
    this.loadUserInfo()
    this.getLocation()
  },
  onShow () {
    this.refreshBadge()
  },
  onShareAppMessage () {
    return {
      title: '推荐给你这个应用',
      path: '/pages/index'
    }
  },
  methods: {
    loadUserInfo () {
      if (isRN) {
        // todo: RN 平台不支持 getStorageSync / setStorageSync，改用异步 getStorage / setStorage；getUserProfile 在 RN 不支持，改为读取异步缓存
        mpx.getStorage({
          key: 'userInfo',
          success: (res) => {
            if (res.data) {
              this.userInfo = typeof res.data === 'string' ? JSON.parse(res.data) : res.data
            }
          }
        })
      } else {
        const cachedInfo = mpx.getStorageSync('userInfo')
        if (cachedInfo) {
          this.userInfo = JSON.parse(cachedInfo)
        } else {
          mpx.getUserProfile({
            desc: '用于展示用户信息',
            success: (res) => {
              this.userInfo = res.userInfo
              mpx.setStorageSync('userInfo', JSON.stringify(res.userInfo))
            },
            fail: () => {
              mpx.showToast({ title: '获取信息失败', icon: 'none' })
            }
          })
        }
      }
    },
    getLocation () {
      mpx.getLocation({
        type: 'gcj02',
        success: (res) => {
          this.locationInfo = { lat: res.latitude, lng: res.longitude }
          if (isRN) {
            // todo: RN 平台不支持 setStorageSync，改用异步 setStorage
            mpx.setStorage({
              key: 'lastLocation',
              data: JSON.stringify(this.locationInfo)
            })
          } else {
            mpx.setStorageSync('lastLocation', JSON.stringify(this.locationInfo))
          }
        }
      })
    },
    onMenuTap (item) {
      mpx.navigateTo({ url: item.path })
    },
    logout () {
      mpx.showModal({
        title: '确认退出',
        content: '确定要退出登录吗？',
        success: (res) => {
          if (res.confirm) {
            mpx.removeStorageSync('userInfo')
            mpx.removeStorageSync('token')
            mpx.reLaunch({ url: '/pages/login' })
          }
        }
      })
    },
    refreshBadge () {
      if (isRN) {
        // todo: getStorageSync 在 RN 不支持，改用异步 getStorage 获取 token；setTabBarBadge / removeTabBarBadge 在 RN 不支持，已通过条件编译隔离
        mpx.getStorage({
          key: 'token',
          success: (res) => {
            const token = res.data || ''
            mpx.request({
              url: '/api/user/badge',
              header: { Authorization: 'Bearer ' + token },
              success: () => {}
            })
          }
        })
      } else {
        mpx.request({
          url: '/api/user/badge',
          header: { Authorization: 'Bearer ' + mpx.getStorageSync('token') },
          success: (res) => {
            if (res.data.orderCount > 0) {
              mpx.setTabBarBadge({
                index: 2,
                text: String(res.data.orderCount)
              })
            } else {
              mpx.removeTabBarBadge({ index: 2 })
            }
          }
        })
      }
    },
    refreshData () {}
  }
}

if (!isRN) {
  // todo: onShareTimeline 在 RN 平台不支持，仅在原平台注册
  pageOptions.onShareTimeline = function () {
    return {
      title: '来看看我的主页',
      imageUrl: this.userInfo.avatarUrl
    }
  }
  // todo: onTabItemTap 在 RN 平台不支持，仅在原平台注册
  pageOptions.onTabItemTap = function (item) {
    if (item.index === 0) {
      this.refreshData()
    }
  }
}

createPage(pageOptions)
</script>

<style lang="less">
.profile-page {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.user-section {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 60rpx;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.menu-list {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-bottom-style: solid;
  border-bottom-color: #f0f0f0;
  border-bottom-width: hairlineWidth;
  /* @mpx-else */
  border-bottom: 1rpx solid #f0f0f0;
  /* @mpx-endif */
}

.menu-label {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.action-section {
  margin-top: 40rpx;
}

.btn-logout {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.btn-text {
  font-size: 30rpx;
  color: #ff4d4f;
}
</style>

<script name="json">
const isRN = __mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony'

if (isRN) {
  // todo: enablePullDownRefresh / onReachBottomDistance / backgroundTextStyle 在 RN 不支持，已通过条件编译隔离；RN 侧设置 disableScroll: true，页面滚动应由 scroll-view 处理
  module.exports = {
    usingComponents: {},
    navigationBarTitleText: '个人中心',
    navigationBarBackgroundColor: '#ffffff',
    disableScroll: true
  }
} else {
  module.exports = {
    usingComponents: {},
    navigationBarTitleText: '个人中心',
    enablePullDownRefresh: true,
    onReachBottomDistance: 50,
    navigationBarBackgroundColor: '#ffffff',
    backgroundTextStyle: 'dark'
  }
}
</script>
