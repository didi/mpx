<template>
  <view class="profile-page">
    <view class="user-section">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="aspectFill"></image>
      <view class="user-info">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="user-id">ID: {{userInfo.userId}}</text>
      </view>
    </view>
    <view class="menu-list">
      <view class="menu-item" wx:for="{{menuItems}}" wx:key="id" bindtap="onMenuTap" data-item="{{item}}">
        <text class="menu-label">{{item.label}}</text>
        <text class="menu-arrow">></text>
      </view>
    </view>
    <view class="action-section">
      <view class="btn-logout" bindtap="logout">
        <text class="btn-text">退出登录</text>
      </view>
    </view>
  </view>
</template>

<script>
import { createPage } from '@mpxjs/core'

createPage({
  data: {
    userInfo: {},
    menuItems: [
      { id: 1, label: '我的订单', path: '/pages/orders' },
      { id: 2, label: '收货地址', path: '/pages/address' },
      { id: 3, label: '账户设置', path: '/pages/settings' },
      { id: 4, label: '关于我们', path: '/pages/about' }
    ],
    locationInfo: null
  },
  onLoad () {
    this.loadUserInfo()
    this.getLocation()
  },
  onShow () {
    this.refreshBadge()
  },
  onShareTimeline () {
    return {
      title: '来看看我的主页',
      imageUrl: this.userInfo.avatarUrl
    }
  },
  onShareAppMessage () {
    return {
      title: '推荐给你这个应用',
      path: '/pages/index'
    }
  },
  onTabItemTap (item) {
    if (item.index === 0) {
      this.refreshData()
    }
  },
  methods: {
    loadUserInfo () {
      const cachedInfo = wx.getStorageSync('userInfo')
      if (cachedInfo) {
        this.userInfo = JSON.parse(cachedInfo)
      } else {
        wx.getUserProfile({
          desc: '用于展示用户信息',
          success: (res) => {
            this.userInfo = res.userInfo
            wx.setStorageSync('userInfo', JSON.stringify(res.userInfo))
          },
          fail: () => {
            wx.showToast({ title: '获取信息失败', icon: 'none' })
          }
        })
      }
    },
    getLocation () {
      wx.getLocation({
        type: 'gcj02',
        success: (res) => {
          this.locationInfo = { lat: res.latitude, lng: res.longitude }
          wx.setStorageSync('lastLocation', JSON.stringify(this.locationInfo))
        }
      })
    },
    onMenuTap (e) {
      const item = e.target.dataset.item
      wx.navigateTo({ url: item.path })
    },
    logout () {
      wx.showModal({
        title: '确认退出',
        content: '确定要退出登录吗？',
        success: (res) => {
          if (res.confirm) {
            wx.removeStorageSync('userInfo')
            wx.removeStorageSync('token')
            wx.reLaunch({ url: '/pages/login' })
          }
        }
      })
    },
    refreshBadge () {
      wx.request({
        url: '/api/user/badge',
        header: { Authorization: 'Bearer ' + wx.getStorageSync('token') },
        success: (res) => {
          if (res.data.orderCount > 0) {
            wx.setTabBarBadge({
              index: 2,
              text: String(res.data.orderCount)
            })
          } else {
            wx.removeTabBarBadge({ index: 2 })
          }
        }
      })
    },
    refreshData () {}
  }
})
</script>

<style lang="less">
.profile-page {
  padding: 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.user-section {
  display: flex;
  align-items: center;
  padding: 32rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  margin-right: 24rpx;
}

.user-info {
  flex: 1;
}

.nickname {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.user-id {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.menu-list {
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.menu-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.menu-label {
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 28rpx;
  color: #ccc;
}

.action-section {
  margin-top: 40rpx;
}

.btn-logout {
  background: #fff;
  border-radius: 12rpx;
  padding: 24rpx;
  text-align: center;
}

.btn-text {
  font-size: 30rpx;
  color: #ff4d4f;
}
</style>

<script type="application/json">
{
  "usingComponents": {},
  "navigationBarTitleText": "个人中心",
  "enablePullDownRefresh": true,
  "onReachBottomDistance": 50,
  "navigationBarBackgroundColor": "#ffffff",
  "backgroundTextStyle": "dark"
}
</script>
