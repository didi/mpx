<template>
  <view class="data-panel">
    <view class="panel-header">
      <text class="title">Data Overview</text>
      <view class="tab-bar">
        <view
          wx:for="{{tabs}}"
          wx:key="id"
          class="tab-item"
          bindtap="switchTab(item.id)"
          wx:class="{{  {tabActive: activeTab === item.id}  }}"
        >
          <text>{{item.label}}</text>
        </view>
      </view>
    </view>

    <scroll-view
      scroll-y
      class="panel-scroll"
      scroll-into-view="section-{{scrollTarget}}"
      bindscroll="handleScroll"
      bindscrolltolower="loadMore"
    >
      <view class="stats-section" id="section-stats" wx:ref>
        <view class="stat-card" wx:for="{{stats}}" wx:key="label"
          style="margin: 16rpx 24rpx; padding: 20rpx 30rpx">
          <text class="stat-value">{{item.value}}</text>
          <text class="stat-label">{{item.label}}</text>
        </view>
      </view>

      <view class="chart-section" id="section-chart" wx:ref>
        <view class="chart-title-wrapper">
          <text class="chart-title">Trend Chart</text>
        </view>
        <view class="chart-container" id="chart" wx:ref>
          <view class="chart-placeholder">
            <view class="chart-gradient-bg"></view>
          </view>
        </view>
      </view>

      <view class="detail-section" id="section-detail" wx:ref>
        <view class="detail-header">
          <text class="detail-title">Details</text>
        </view>
        <view class="detail-list">
          <view
            wx:for="{{details}}"
            wx:key="id"
            class="detail-item"
          >
            <view class="detail-row">
              <text class="detail-name">{{item.name}}</text>
              <text class="detail-amount">{{item.amount}}</text>
            </view>
            <view class="detail-bar-wrapper">
              <view class="detail-bar" wx:style="{{  {width: item.percent + '%'}  }}"></view>
            </view>
          </view>
        </view>
      </view>
    </scroll-view>
  </view>
</template>

<script>
import { createComponent, ref, onMounted } from '@mpxjs/core'

createComponent({
  setup (props, context) {
    const tabs = ref([
      { id: 'daily', label: 'Day' },
      { id: 'weekly', label: 'Week' },
      { id: 'monthly', label: 'Month' }
    ])
    const activeTab = ref('daily')
    const scrollTarget = ref('')
    const stats = ref([
      { label: 'Revenue', value: '12,580' },
      { label: 'Orders', value: '356' },
      { label: 'Users', value: '1,024' },
      { label: 'Conversion', value: '3.2%' }
    ])
    const details = ref([])

    onMounted(() => {
      measureChart()
      fetchDetails()
    })

    function measureChart () {
      context.createSelectorQuery()
        .select('.chart-container')
        .boundingClientRect()
        .exec((res) => {
          if (res && res[0]) {
            console.log('chart size:', res[0].width, res[0].height)
          }
        })
    }

    function switchTab (tabId) {
      activeTab.value = tabId
      scrollTarget.value = 'stats'
      fetchDetails()
    }

    function handleScroll (e) {
      console.log('scroll position:', e.detail.scrollTop)
    }

    function loadMore () {
      mpx.showToast({ title: 'Loading more...' })
    }

    function fetchDetails () {
      mpx.request({
        url: '/api/details',
        data: { tab: activeTab.value },
        success (res) {
          details.value = res.data.list
        }
      })
    }

    return {
      tabs,
      activeTab,
      scrollTarget,
      stats,
      details,
      switchTab,
      handleScroll,
      loadMore
    }
  }
})
</script>

<style>
.data-panel {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100vh;
  background-color: #f5f7fa;
}

.panel-header {
  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  /* todo: RN 不支持 position: sticky，RN 侧 panel-header 不具备吸顶能力 */
  position: sticky;
  top: 0;
  z-index: 10;
  /* @mpx-endif */
  background-color: #fff;
  padding: 20rpx 30rpx; /*use rpx*/
  border-bottom: 1px solid #eee; /*use px*/
}

/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
/* todo: RN 不支持 background-image 渐变文字（background-clip: text），RN 侧仅展示纯色文字 */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
  background-image: linear-gradient(90deg, #667eea, #764ba2);
  -webkit-background-clip: text;
}
/* @mpx-endif */
/* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
.title {
  font-size: 36rpx;
  font-weight: bold;
  color: #1a1a2e;
}
/* @mpx-endif */

.tab-bar {
  display: flex;
  flex-direction: row;
  margin-top: 20rpx;
  gap: 16rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  border-radius: 20rpx;
  background-color: #f0f0f0;
  font-size: 24rpx;
  color: #666;
}

.tabActive {
  background-color: #667eea;
  color: #fff;
}

.panel-scroll {
  flex: 1;
  height: 100%;
}

.stats-section {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  padding: 10rpx;
}

.stat-card {
  width: 50%;
  background-color: #fff;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stat-value {
  font-size: 40rpx;
  font-weight: bold;
  color: #1a1a2e;
}

.stat-label {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

.chart-section {
  margin: 20rpx;
  background-color: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.chart-title-wrapper {
  margin-bottom: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.chart-container {
  width: 100%;
  height: 400rpx;
  position: relative;
}

/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
/* todo: RN 不支持 radial-gradient，RN 侧改为线性渐变等效替代 */
.chart-gradient-bg {
  width: 100%;
  height: 100%;
  background-image: radial-gradient(circle at center, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  opacity: 0.1;
}
/* @mpx-endif */
/* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
.chart-gradient-bg {
  width: 100%;
  height: 100%;
  background-image: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  opacity: 0.1;
}
/* @mpx-endif */

.detail-section {
  margin: 20rpx;
}

.detail-header {
  margin-bottom: 16rpx;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.detail-list {
  background-color: #fff;
  border-radius: 16rpx;
  padding: 20rpx;
}

.detail-item {
  padding: 16rpx 0;
  border-bottom: 1px solid #f0f0f0;
}

.detail-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.detail-name {
  font-size: 26rpx;
  color: #333;
}

.detail-amount {
  font-size: 26rpx;
  color: #667eea;
  font-weight: bold;
}

.detail-bar-wrapper {
  height: 8rpx;
  background-color: #f0f0f0;
  border-radius: 4rpx;
  margin-top: 12rpx;
}

.detail-bar {
  height: 100%;
  background-image: linear-gradient(90deg, #667eea, #764ba2);
  border-radius: 4rpx;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {}
}
</script>
