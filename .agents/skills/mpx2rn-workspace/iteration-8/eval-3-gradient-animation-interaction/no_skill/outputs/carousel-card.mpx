<template>
  <view class="carousel-card">
    <view class="card-header">
      <view class="gradient-overlay">
        <text class="card-title">{{title}}</text>
        <text class="card-subtitle">{{subtitle}}</text>
      </view>
    </view>

    <view class="card-body">
      <view
        wx:for="{{items}}"
        wx:key="id"
        class="card-item"
        bindtap="handleItemTap"
        data-id="{{item.id}}"
      >
        <image class="item-image" src="{{item.cover}}" mode="aspectFill" />
        <view class="item-info">
          <text class="item-name">{{item.name}}</text>
          <text class="item-price">{{item.price}}</text>
        </view>
        <view wx:if="{{item.isNew}}" class="item-badge">
          <text class="item-badge-text">NEW</text>
        </view>
      </view>
    </view>

    <view class="card-footer">
      <view class="load-trigger">
        <text wx:if="{{loading}}" class="loading-text">loading...</text>
      </view>
    </view>

    <view
      wx:if="{{showToast}}"
      class="toast-mask"
      bindtap="hideToast"
    >
      <view class="toast-content">
        <text class="toast-text">{{toastMsg}}</text>
      </view>
    </view>
  </view>
</template>

<script>
import { createComponent, ref, onMounted } from '@mpxjs/core'
import mpx from '@mpxjs/core'

createComponent({
  properties: {
    title: { type: String, value: 'Featured' },
    subtitle: { type: String, value: '' }
  },
  setup (props, context) {
    const items = ref([])
    const loading = ref(false)
    const showToast = ref(false)
    const toastMsg = ref('')

    onMounted(() => {
      initObserver()
    })

    function initObserver () {
      // IntersectionObserver is not supported in RN; use scroll-based detection instead
      // For RN platform, load initial data directly
      loadMore()
    }

    function loadMore () {
      if (loading.value) return
      loading.value = true
      mpx.request({
        url: '/api/items',
        data: { page: Math.floor(items.value.length / 10) + 1 },
        success (res) {
          items.value = items.value.concat(res.data.list)
          loading.value = false
        },
        fail () {
          loading.value = false
        }
      })
    }

    function handleItemTap (e) {
      const id = e.currentTarget.dataset.id
      mpx.navigateTo({ url: `/pages/detail/index?id=${id}` })
    }

    function hideToast () {
      showToast.value = false
    }

    return {
      items,
      loading,
      showToast,
      toastMsg,
      handleItemTap,
      hideToast
    }
  }
})
</script>

<style>
.carousel-card {
  width: 100%;
  flex: 1;
}

.card-header {
  position: relative;
  height: 360rpx;
  overflow: hidden;
}

.gradient-overlay {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  padding: 30rpx;
  background-color: #ff6b6b;
}

.card-title {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.card-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-top: 8rpx;
}

.card-body {
  padding: 20rpx;
}

.card-item {
  display: flex;
  flex-direction: row;
  align-items: center;
  padding-top: 24rpx;
  padding-bottom: 24rpx;
  border-bottom-width: 1px;
  border-bottom-color: #eee;
  border-bottom-style: solid;
}

.item-image {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
}

.item-info {
  flex: 1;
  margin-left: 24rpx;
}

.item-name {
  font-size: 28rpx;
  color: #333;
}

.item-price {
  font-size: 32rpx;
  color: #ff4d4f;
  margin-top: 8rpx;
  font-weight: bold;
}

.item-badge {
  padding-top: 4rpx;
  padding-bottom: 4rpx;
  padding-left: 12rpx;
  padding-right: 12rpx;
  background-color: #ff4d4f;
  border-radius: 4rpx;
}

.item-badge-text {
  color: #fff;
  font-size: 20rpx;
}

.card-footer {
  padding: 20rpx;
}

.load-trigger {
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

.toast-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.toast-content {
  padding-top: 24rpx;
  padding-bottom: 24rpx;
  padding-left: 48rpx;
  padding-right: 48rpx;
  background-color: #fff;
  border-radius: 16rpx;
}

.toast-text {
  font-size: 28rpx;
  color: #333;
}
</style>

<script type="application/json">
{
  "component": true,
  "usingComponents": {}
}
</script>
