<template>
  <scroll-view class="order-page" scroll-y enable-back-to-top bindscrolltolower="loadMore">
    <view class="tab-bar">
      <view
        class="tab"
        wx:for="{{tabs}}"
        wx:key="key"
        bindtap="switchTab(item.key)"
      >
        <text class="tab-text" wx:class="{{'tab-text-active': activeTab === item.key}}">{{item.label}}</text>
        <view wx:if="{{item.badge > 0}}" class="badge">
          <text class="badge-text">{{item.badge > 99 ? '99+' : item.badge}}</text>
        </view>
      </view>
    </view>

    <view class="order-list">
      <view
        class="order-item"
        wx:for="{{ordersWithStyle}}"
        wx:key="id"
        bindtap="goOrderDetail(item.id)"
        bindlongpress="showActions(item.id, item.status)"
      >
        <view class="order-header">
          <text class="order-no">订单号: {{item.orderNo}}</text>
          <text class="order-status" wx:style="{{item.statusStyle}}">{{item.statusText}}</text>
        </view>
        <view class="order-goods">
          <image class="goods-img" src="{{item.goodsImg}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-name">{{item.goodsName}}</text>
            <text class="goods-spec">{{item.spec}}</text>
            <view class="goods-price-row">
              <text class="goods-price">¥{{item.price}}</text>
              <text class="goods-count">x{{item.count}}</text>
            </view>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-total">合计: ¥{{item.totalPrice}}</text>
          <view class="order-actions">
            <view
              wx:if="{{item.status === 'unpaid'}}"
              class="btn btn-primary"
              bindtap="payOrder(item.id)"
            >
              <text class="btn-text">去支付</text>
            </view>
            <view
              wx:if="{{item.status === 'shipped'}}"
              class="btn btn-default"
              bindtap="confirmReceive(item.id)"
            >
              <text class="btn-text btn-text-default">确认收货</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:if="{{!loading && orders.length === 0}}" class="empty">
      <text class="empty-text">暂无订单</text>
    </view>
  </scroll-view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import mpx from '@mpxjs/core'

createPage({
  data: {
    activeTab: 'all',
    tabs: [
      { key: 'all', label: '全部', badge: 0 },
      { key: 'unpaid', label: '待付款', badge: 3 },
      { key: 'shipped', label: '待收货', badge: 1 },
      { key: 'completed', label: '已完成', badge: 0 }
    ],
    orders: [],
    loading: false
  },
  computed: {
    ordersWithStyle () {
      const colorMap = { unpaid: '#ff4d4f', shipped: '#1677ff', completed: '#52c41a' }
      const textMap = { unpaid: '待付款', shipped: '已发货', completed: '已完成' }
      return this.orders.map(order => ({
        ...order,
        statusStyle: { color: colorMap[order.status] || '#999' },
        statusText: textMap[order.status] || '未知'
      }))
    }
  },
  onLoad () {
    this.fetchOrders()
  },
  // onPullDownRefresh 在 RN 中无效，通过 scroll-view 替代
  onPullDownRefresh () {
    if (__mpx_mode__ !== 'ios' && __mpx_mode__ !== 'android' && __mpx_mode__ !== 'harmony') {
      this.fetchOrders()
    }
  },
  methods: {
    getStatusColor (status) {
      const map = { unpaid: '#ff4d4f', shipped: '#1677ff', completed: '#52c41a' }
      return map[status] || '#999'
    },
    getStatusText (status) {
      const map = { unpaid: '待付款', shipped: '已发货', completed: '已完成' }
      return map[status] || '未知'
    },
    switchTab (key) {
      this.activeTab = key
      this.fetchOrders()
    },
    goOrderDetail (id) {
      mpx.navigateTo({ url: '/pages/order-detail?id=' + id })
    },
    showActions (id, status) {
      mpx.showActionSheet({
        itemList: status === 'unpaid' ? ['取消订单', '联系客服'] : ['联系客服'],
        success: (res) => {
          if (res.tapIndex === 0 && status === 'unpaid') {
            this.cancelOrder(id)
          }
        }
      })
    },
    payOrder (id) {
      mpx.navigateTo({ url: '/pages/pay?orderId=' + id })
    },
    confirmReceive (id) {
      mpx.showModal({
        title: '确认收货',
        content: '确认已收到商品？',
        success: (res) => {
          if (res.confirm) {
            this.doConfirmReceive(id)
          }
        }
      })
    },
    fetchOrders () {
      this.loading = true
      mpx.request({
        url: '/api/orders',
        data: { status: this.activeTab },
        success: (res) => {
          this.orders = res.data.list
          this.loading = false
        }
      })
    },
    loadMore () {},
    cancelOrder (id) {},
    doConfirmReceive (id) {}
  }
})
</script>

<style lang="less">
.order-page {
  padding: 0 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.tab {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  padding: 12rpx 0;
}

.tab-text {
  font-size: 28rpx;
}

.tab-text-active {
  color: #1677ff;
  font-weight: bold;
}

.badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  background: #ff4d4f;
  border-radius: 16rpx;
  padding: 0 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
}

.order-item {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-goods {
  display: flex;
  padding: 16rpx 0;
  border-top-width: 1rpx;
  border-top-style: solid;
  border-top-color: #f0f0f0;
  border-bottom-width: 1rpx;
  border-bottom-style: solid;
  border-bottom-color: #f0f0f0;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
}

.goods-price-row {
  display: flex;
  justify-content: space-between;
}

.goods-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.order-total {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.order-actions {
  display: flex;
}

.btn {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  margin-left: 16rpx;
}

.btn-primary {
  background: #1677ff;
}

.btn-default {
  background: #fff;
  border-width: 1rpx;
  border-style: solid;
  border-color: #ddd;
}

.btn-text {
  font-size: 24rpx;
  color: #fff;
}

.btn-text-default {
  color: #333;
}

.loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.empty {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
</style>

<script name="json">
const isRN = __mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony'

module.exports = {
  usingComponents: {},
  navigationBarTitleText: 'My Orders',
  disableScroll: isRN ? true : false,
  enablePullDownRefresh: isRN ? false : true,
  onReachBottomDistance: isRN ? undefined : 50
}
</script>
