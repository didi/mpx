<template>
  <scroll-view
    class="order-page"
    scroll-y
    enhanced
    refresher-enabled
    refresher-triggered="{{isRefreshing}}"
    bindrefresherrefresh="onPullDownRefreshRN"
    bindscrolltolower="onReachBottomRN"
    lower-threshold="{{50}}"
  >
    <view class="tab-bar">
      <view
        wx:for="{{tabs}}"
        wx:key="key"
        class="tab"
        bindtap="switchTab(item.key)"
      >
        <text
          class="tab-text"
          wx:class="{{ {'tab-text-active': activeTab === item.key} }}"
        >{{item.label}}</text>
        <view wx:if="{{item.badge > 0}}" class="badge">
          <text class="badge-text">{{item.badge > 99 ? '99+' : item.badge}}</text>
        </view>
      </view>
    </view>

    <view class="order-list">
      <view
        wx:for="{{orders}}"
        wx:key="id"
        class="order-item"
        bindtap="goOrderDetail(item.id)"
        bindlongpress="showActions(item.id, item.status)"
      >
        <view class="order-header">
          <text class="order-no">订单号: {{item.orderNo}}</text>
          <text class="order-status" wx:style="{{ {color: statusColorMap[item.status] || '#999'} }}">{{statusTextMap[item.status] || '未知'}}</text>
        </view>
        <view class="order-goods">
          <image class="goods-img" src="{{item.goodsImg}}" mode="aspectFill"></image>
          <view class="goods-info">
            <text class="goods-name">{{item.goodsName}}</text>
            <text class="goods-spec">{{item.spec}}</text>
            <view class="goods-price-row">
              <text class="goods-price">¥{{item.price}}</text>
              <text class="goods-count">x{{item.count}}</text>
            </view>
          </view>
        </view>
        <view class="order-footer">
          <text class="order-total">合计: ¥{{item.totalPrice}}</text>
          <view class="order-actions">
            <view
              wx:if="{{item.status === 'unpaid'}}"
              class="btn btn-primary"
              bindtap="payOrder(item.id)"
            >
              <text class="btn-text">去支付</text>
            </view>
            <view
              wx:if="{{item.status === 'shipped'}}"
              class="btn btn-default"
              bindtap="confirmReceive(item.id)"
            >
              <text class="btn-default-text">确认收货</text>
            </view>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loading}}" class="loading">
      <text class="loading-text">加载中...</text>
    </view>
    <view wx:if="{{!loading && orders.length === 0}}" class="empty">
      <text class="empty-text">暂无订单</text>
    </view>
  </scroll-view>
</template>

<script>
import mpx, { createPage } from '@mpxjs/core'

createPage({
  data: {
    activeTab: 'all',
    tabs: [
      { key: 'all', label: '全部', badge: 0 },
      { key: 'unpaid', label: '待付款', badge: 3 },
      { key: 'shipped', label: '待收货', badge: 1 },
      { key: 'completed', label: '已完成', badge: 0 }
    ],
    orders: [],
    loading: false,
    isRefreshing: false,
    statusColorMap: { unpaid: '#ff4d4f', shipped: '#1677ff', completed: '#52c41a' },
    statusTextMap: { unpaid: '待付款', shipped: '已发货', completed: '已完成' }
  },
  onLoad () {
    this.fetchOrders()
  },
  // todo: onPullDownRefresh 在 RN 平台无效，RN 侧通过 scroll-view refresher 能力实现等效下拉刷新
  onPullDownRefresh () {
    this.fetchOrders()
  },
  // todo: onReachBottom 在 RN 平台无效，RN 侧通过 scroll-view bindscrolltolower 实现等效触底加载
  onReachBottom () {
    this.loadMore()
  },
  methods: {
    // RN 下拉刷新处理（scroll-view refresher）
    onPullDownRefreshRN () {
      this.isRefreshing = true
      this.fetchOrders(() => {
        this.isRefreshing = false
      })
    },
    // RN 触底加载处理（scroll-view scrolltolower）
    onReachBottomRN () {
      this.loadMore()
    },
    switchTab (key) {
      this.activeTab = key
      this.fetchOrders()
    },
    goOrderDetail (id) {
      mpx.navigateTo({ url: '/pages/order-detail?id=' + id })
    },
    showActions (id, status) {
      mpx.showActionSheet({
        itemList: status === 'unpaid' ? ['取消订单', '联系客服'] : ['联系客服'],
        success: (res) => {
          if (res.tapIndex === 0 && status === 'unpaid') {
            this.cancelOrder(id)
          }
        }
      })
    },
    payOrder (id) {
      mpx.navigateTo({ url: '/pages/pay?orderId=' + id })
    },
    confirmReceive (id) {
      mpx.showModal({
        title: '确认收货',
        content: '确认已收到商品？',
        success: (res) => {
          if (res.confirm) {
            this.doConfirmReceive(id)
          }
        }
      })
    },
    fetchOrders (callback) {
      this.loading = true
      mpx.request({
        url: '/api/orders',
        data: { status: this.activeTab },
        success: (res) => {
          this.orders = res.data.list
          this.loading = false
          if (callback) callback()
        }
      })
    },
    loadMore () {},
    cancelOrder (id) {},
    doConfirmReceive (id) {}
  }
})
</script>

<style lang="less">
.order-page {
  padding: 0 24rpx;
  background: #f5f5f5;
  min-height: 100vh;
}

.tab-bar {
  display: flex;
  flex-direction: row;
  padding: 20rpx 0;
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
}

.tab {
  flex: 1;
  position: relative;
  padding: 12rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.tab-text {
  font-size: 28rpx;
}

.tab-text-active {
  color: #1677ff;
  font-weight: bold;
}

.badge {
  position: absolute;
  top: 0;
  right: 20rpx;
  background: #ff4d4f;
  border-radius: 16rpx;
  padding: 0 8rpx;
  min-width: 28rpx;
  height: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.badge-text {
  font-size: 20rpx;
  color: #fff;
}

.order-item {
  background: #fff;
  border-radius: 8rpx;
  margin-bottom: 16rpx;
  padding: 24rpx;
}

.order-header {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.order-no {
  font-size: 24rpx;
  color: #999;
}

.order-status {
  font-size: 26rpx;
  font-weight: bold;
}

.order-goods {
  display: flex;
  flex-direction: row;
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.goods-img {
  width: 160rpx;
  height: 160rpx;
  border-radius: 8rpx;
  margin-right: 16rpx;
}

.goods-info {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.goods-name {
  font-size: 28rpx;
  color: #333;
}

.goods-spec {
  font-size: 24rpx;
  color: #999;
}

.goods-price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
}

.goods-price {
  font-size: 28rpx;
  color: #ff4d4f;
  font-weight: bold;
}

.goods-count {
  font-size: 24rpx;
  color: #999;
}

.order-footer {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.order-total {
  font-size: 28rpx;
  color: #333;
  font-weight: bold;
}

.order-actions {
  display: flex;
  flex-direction: row;
}

.btn {
  padding: 10rpx 24rpx;
  border-radius: 32rpx;
  margin-left: 16rpx;
}

.btn-primary {
  background: #1677ff;
}

.btn-default {
  background: #fff;
  border: 1rpx solid #ddd;
}

.btn-text {
  font-size: 24rpx;
  color: #fff;
}

.btn-default-text {
  font-size: 24rpx;
  color: #333;
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}
</style>

<script name="json">
const isRN = __mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony'

module.exports = isRN ? {
  usingComponents: {},
  navigationBarTitleText: 'My Orders',
  disableScroll: true
} : {
  usingComponents: {},
  navigationBarTitleText: 'My Orders',
  enablePullDownRefresh: true,
  onReachBottomDistance: 50
}
</script>
