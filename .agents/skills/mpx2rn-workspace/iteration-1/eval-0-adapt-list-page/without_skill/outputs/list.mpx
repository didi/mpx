<template>
  <view class="list">
    <view class="list-header">
      <text class="title">列表标题</text>
    </view>
    <view
      class="item {{currentId === item.id ? 'item-active' : ''}}"
      wx:for="{{items}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <text class="content" :numberOfLines="1">{{item.text}}</text>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import mpx from '@mpxjs/core'
import apiProxy from '@mpxjs/api-proxy'

mpx.use(apiProxy, {
  usePromise: true,
  custom: {
    /* @mpx-if(__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
    request: require('@mpxjs/fetch').default
    /* @mpx-end-if */
  }
})

createPage({
  data: {
    items: [],
    loading: false,
    currentId: null
  },
  onLoad () {
    this.fetchList()
  },
  onPullDownRefresh () {
    this.fetchList()
  },
  onReachBottom () {
    this.loadMore()
  },
  methods: {
    fetchList () {
      this.loading = true
      mpx.request({
        url: '/api/list',
        success: (res) => {
          this.items = res.data
          this.loading = false
        },
        fail: () => {
          this.loading = false
        }
      })
    },
    loadMore () {},
    goDetail (e) {
      const id = e.currentTarget.dataset.id
      this.currentId = id
      mpx.navigateTo({ url: '/pages/detail?id=' + id })
    }
  }
})
</script>

<style lang="less">
.list {
  padding: 24rpx;
}
.list-header {
  /* RN 不支持后代选择器，将 .title 单独提到顶层；这里仅保留布局相关样式 */
}
.title {
  font-size: 36rpx;
  font-weight: 500;
  color: #333;
}
.item {
  padding: 20rpx;
  /* RN 不支持 border 简写，需要分开写各边 */
  border-bottom-width: 1rpx;
  border-bottom-style: solid;
  border-bottom-color: #eee;
  /* RN 不支持 :first-child / :active 伪类，已在 H5/小程序中保留通过条件编译 */
  /* @mpx-if(__mpx_mode__ === 'wx' || __mpx_mode__ === 'web') */
  &:first-child {
    border-top: 1rpx solid #eee;
  }
  &:active {
    background-color: #f5f5f5;
  }
  /* @mpx-end-if */
}
.content {
  font-size: 28rpx;
  color: #666;
  /* RN 中 text-overflow / white-space / overflow 对文本省略不生效，
     已在 template 中通过 numberOfLines=1 实现单行省略，这里仅保留 H5/小程序兼容样式 */
  /* @mpx-if(__mpx_mode__ === 'wx' || __mpx_mode__ === 'web') */
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  /* @mpx-end-if */
}
.item-active {
  background-color: #e8f0ff;
}
.loading {
  /* RN 不支持 display: none / display: block，本组件通过 wx:if 控制显隐，
     这里仅保留文字样式 */
  text-align: center;
  padding: 20rpx;
}
</style>
