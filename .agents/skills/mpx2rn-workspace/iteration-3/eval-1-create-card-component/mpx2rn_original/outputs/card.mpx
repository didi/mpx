<template>
  <view
    class="card"
    wx:class="{{ {cardSelected: selected} }}"
    hover-class="card-hover"
    hover-stay-time="{{100}}"
    bindtap="handleTap"
  >
    <image class="card-avatar" src="{{avatar}}" mode="aspectFill" />
    <view class="card-content">
      <text
        class="card-title"
        numberOfLines@ios|android|harmony="{{1}}"
      >{{title}}</text>
      <text
        class="card-desc"
        numberOfLines@ios|android|harmony="{{2}}"
      >{{desc}}</text>
    </view>
  </view>
</template>

<script setup>
  import { toRefs } from '@mpxjs/core'

  const props = defineProps({
    title: {
      type: String,
      value: ''
    },
    desc: {
      type: String,
      value: ''
    },
    avatar: {
      type: String,
      value: ''
    },
    selected: {
      type: Boolean,
      value: false
    }
  })

  const { title, desc, avatar, selected } = toRefs(props)

  const context = useContext()

  function handleTap() {
    context.triggerEvent('tap')
  }

  defineExpose({
    title,
    desc,
    avatar,
    selected,
    handleTap
  })
</script>

<script type="application/json">
  {
    "component": true
  }
</script>

<style>
  .card {
    display: flex;
    flex-direction: row;
    align-items: center;
    padding: 24rpx;
    background-color: #ffffff;
    border: 1px solid #e5e5e5;
    border-radius: 16rpx;
    overflow: hidden;
  }

  .cardSelected {
    border-color: #1677ff;
  }

  .card-hover {
    opacity: 0.7;
    background-color: #f5f5f5;
  }

  .card-avatar {
    width: 96rpx;
    height: 96rpx;
    border-radius: 48rpx;
    margin-right: 24rpx;
  }

  .card-content {
    flex: 1;
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .card-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333333;
    margin-bottom: 8rpx;
  }

  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  .card-title {
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  /* @mpx-endif */

  .card-desc {
    font-size: 26rpx;
    color: #999999;
    line-height: 36rpx;
  }

  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  .card-desc {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  /* @mpx-endif */
</style>
