<template>
  <view class="product-page">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索商品" bindinput="onSearch" value="{{keyword}}" />
      <view class="search-btn" hover-class="search-btn-hover" hover-stay-time="{{100}}" bindtap="doSearch">
        <text class="search-btn-text">搜索</text>
      </view>
    </view>
    <view class="filter-bar">
      <view
        class="filter-item"
        wx:class="{{{'filter-item-active': activeFilter === 'price'}}}"
        hover-class="filter-item-hover"
        hover-stay-time="{{100}}"
        bindtap="switchFilter('price')"
      >
        <text>价格</text>
      </view>
      <view
        class="filter-item"
        wx:class="{{{'filter-item-active': activeFilter === 'sales'}}}"
        hover-class="filter-item-hover"
        hover-stay-time="{{100}}"
        bindtap="switchFilter('sales')"
      >
        <text>销量</text>
      </view>
    </view>
    <scroll-view
      class="product-scroll"
      scroll-y
      refresher-enabled
      refresher-triggered="{{refreshing}}"
      bindrefresherrefresh="onRefresh"
      bindscrolltolower="onScrollToLower"
      bindscroll="onScroll"
      lower-threshold="{{100}}"
      enable-trigger-intersection-observer
    >
      <view class="product-list">
        <view
          class="product-card"
          hover-class="product-card-hover"
          hover-stay-time="{{100}}"
          wx:for="{{products}}"
          wx:key="id"
          bindtap="goDetail(item.id)"
        >
          <image class="product-img" src="{{item.image}}" mode="aspectFill" />
          <view class="product-info">
            <text
              class="product-name"
              numberOfLines@ios|android|harmony="{{1}}"
            >{{item.name}}</text>
            <view class="product-tags">
              <text class="product-tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
            <view class="price-row">
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-sales">已售 {{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="exposure-tracker" id="exposureAnchor" wx:ref>
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:elif="{{noMore}}">没有更多了</text>
      </view>
    </scroll-view>
  </view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import mpx from '@mpxjs/core'
import { useProductStore } from '@/stores/product'

createPage({
  data: {
    keyword: '',
    activeFilter: 'price',
    loading: false,
    noMore: false,
    showBackTop: false,
    refreshing: false
  },
  computed: {
    products () {
      const store = useProductStore()
      return store.filteredProducts
    }
  },
  onLoad () {
    this.fetchProducts()
    this.setupExposure()
  },
  methods: {
    onRefresh () {
      this.refreshing = true
      this.keyword = ''
      this.fetchProducts()
    },
    onScrollToLower () {
      if (!this.loading && !this.noMore) {
        this.loadMore()
      }
    },
    onScroll (e) {
      if (e.detail.scrollTop > 200) {
        this.showBackTop = true
      } else {
        this.showBackTop = false
      }
    },
    fetchProducts () {
      this.loading = true
      const store = useProductStore()
      mpx.request({
        url: '/api/products',
        data: { keyword: this.keyword, filter: this.activeFilter },
        success: (res) => {
          store.setProducts(res.data.list)
          this.loading = false
          this.noMore = res.data.list.length < 20
          this.refreshing = false
        }
      })
    },
    loadMore () {
      this.loading = true
      const store = useProductStore()
      mpx.request({
        url: '/api/products',
        data: {
          keyword: this.keyword,
          filter: this.activeFilter,
          page: store.currentPage + 1
        },
        success: (res) => {
          store.appendProducts(res.data.list)
          this.loading = false
          this.noMore = res.data.list.length < 20
        }
      })
    },
    setupExposure () {
      this.createIntersectionObserver()
        .observe('#exposureAnchor', (res) => {
          if (res.intersectionRatio > 0 && !this.loading && !this.noMore) {
            this.loadMore()
          }
        })
    },
    onSearch (e) {
      this.keyword = e.detail.value
    },
    doSearch () {
      this.fetchProducts()
    },
    switchFilter (type) {
      this.activeFilter = type
      const store = useProductStore()
      store.setFilter(this.activeFilter)
      this.fetchProducts()
    },
    goDetail (id) {
      mpx.navigateTo({ url: '/pages/product/detail?id=' + id })
    }
  }
})
</script>

<style lang="less">
.product-page {
  display: flex;
  flex-direction: column;
  padding: 20rpx;
  flex: 1;
}

.search-bar {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  border-style: solid;
  border-color: #ddd;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  /* @mpx-else */
  border-width: 1rpx;
  /* @mpx-endif */
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  margin-left: 16rpx;
  background: #ff6b00;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn-hover {
  opacity: 0.7;
}

.search-btn-text {
  color: white;
  font-size: 28rpx;
}

.filter-bar {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background: #f5f5f5;
}

.filter-item-hover {
  opacity: 0.7;
}

.filter-item-active {
  background: #ff6b00;
  color: white;
}

.product-scroll {
  flex: 1;
}

.product-card {
  display: flex;
  flex-direction: row;
  padding: 20rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  border-style: solid;
  border-color: #eee;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  /* @mpx-else */
  border-width: 1rpx;
  /* @mpx-endif */
}

.product-card-hover {
  background: #fafafa;
}

.product-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.product-info {
  margin-left: 20rpx;
  flex: 1;
}

.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
/* todo: RN 不支持 white-space / text-overflow，使用 numberOfLines 模板属性替代 */
.product-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* @mpx-endif */

.product-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.product-tag {
  font-size: 20rpx;
  color: #ff6b00;
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
  border-style: solid;
  border-color: #ff6b00;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  /* @mpx-else */
  border-width: 1rpx;
  /* @mpx-endif */
}

.price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

.exposure-tracker {
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>
