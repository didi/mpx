<template>
  <view class="product-page">
    <view class="search-bar">
      <input class="search-input" placeholder="搜索商品" bindinput="onSearch" value="{{keyword}}" />
      <view class="search-btn" bindtap="doSearch" hover-class="search-btn-hover" hover-stay-time="{{100}}">
        <text class="btn-text">搜索</text>
      </view>
    </view>
    <view class="filter-bar">
      <view
        class="filter-item"
        wx:class="{{{'filter-active': activeFilter === 'price'}}}"
        data-type="price"
        bindtap="switchFilter"
        hover-class="filter-item-hover"
        hover-stay-time="{{100}}"
      >
        <text>价格</text>
      </view>
      <view
        class="filter-item"
        wx:class="{{{'filter-active': activeFilter === 'sales'}}}"
        data-type="sales"
        bindtap="switchFilter"
        hover-class="filter-item-hover"
        hover-stay-time="{{100}}"
      >
        <text>销量</text>
      </view>
    </view>
    <scroll-view
      class="product-scroll"
      scroll-y
      enable-trigger-intersection-observer="{{true}}"
      refresher-enabled="{{true}}"
      refresher-triggered="{{refreshing}}"
      bindrefresherrefresh="onRefresh"
      bindscrolltolower="onScrollToLower"
      bindscroll="onScroll"
    >
      <view class="product-list">
        <view
          class="product-card"
          wx:for="{{products}}"
          wx:key="id"
          data-id="{{item.id}}"
          bindtap="goDetail"
          hover-class="product-card-hover"
          hover-stay-time="{{100}}"
        >
          <image class="product-img" src="{{item.image}}" mode="aspectFill" />
          <view class="product-info">
            <text class="product-name" numberOfLines@ios|android|harmony="{{1}}">{{item.name}}</text>
            <view class="product-tags">
              <text class="tag" wx:for="{{item.tags}}" wx:for-item="tag" wx:key="*this">{{tag}}</text>
            </view>
            <view class="price-row">
              <text class="product-price">¥{{item.price}}</text>
              <text class="product-sales">已售 {{item.sales}}</text>
            </view>
          </view>
        </view>
      </view>
      <view class="exposure-tracker" id="exposureAnchor" wx:ref>
        <text wx:if="{{loading}}">加载中...</text>
        <text wx:elif="{{noMore}}">没有更多了</text>
      </view>
    </scroll-view>
  </view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import mpx from '@mpxjs/core'
import { useProductStore } from '@/stores/product'

createPage({
  data: {
    keyword: '',
    activeFilter: 'price',
    loading: false,
    noMore: false,
    showBackTop: false,
    refreshing: false
  },
  computed: {
    products () {
      const store = useProductStore()
      return store.filteredProducts
    }
  },
  onLoad () {
    this.fetchProducts()
    this.setupExposure()
  },
  methods: {
    fetchProducts () {
      this.loading = true
      const store = useProductStore()
      mpx.request({
        url: '/api/products',
        data: { keyword: this.keyword, filter: this.activeFilter },
        success: (res) => {
          store.setProducts(res.data.list)
          this.loading = false
          this.noMore = res.data.list.length < 20
        }
      })
    },
    loadMore () {
      this.loading = true
      const store = useProductStore()
      mpx.request({
        url: '/api/products',
        data: {
          keyword: this.keyword,
          filter: this.activeFilter,
          page: store.currentPage + 1
        },
        success: (res) => {
          store.appendProducts(res.data.list)
          this.loading = false
          this.noMore = res.data.list.length < 20
        }
      })
    },
    setupExposure () {
      this.createIntersectionObserver()
        .observe('#exposureAnchor', (res) => {
          if (res.intersectionRatio > 0 && !this.loading && !this.noMore) {
            this.loadMore()
          }
        })
    },
    onSearch (e) {
      this.keyword = e.detail.value
    },
    doSearch () {
      this.fetchProducts()
    },
    switchFilter (e) {
      this.activeFilter = e.currentTarget.dataset.type
      const store = useProductStore()
      store.setFilter(this.activeFilter)
      this.fetchProducts()
    },
    goDetail (e) {
      const id = e.currentTarget.dataset.id
      mpx.navigateTo({ url: '/pages/product/detail?id=' + id })
    },
    onRefresh () {
      this.refreshing = true
      this.keyword = ''
      const store = useProductStore()
      mpx.request({
        url: '/api/products',
        data: { keyword: this.keyword, filter: this.activeFilter },
        success: (res) => {
          store.setProducts(res.data.list)
          this.loading = false
          this.noMore = res.data.list.length < 20
          this.refreshing = false
        },
        fail: () => {
          this.refreshing = false
        }
      })
    },
    onScrollToLower () {
      if (!this.loading && !this.noMore) {
        this.loadMore()
      }
    },
    onScroll (e) {
      if (e.detail.scrollTop > 200) {
        this.showBackTop = true
      } else {
        this.showBackTop = false
      }
    }
  }
})
</script>

<style lang="less">
.product-page {
  padding: 20rpx;
  display: flex;
  flex-direction: column;
  flex: 1;
}

.search-bar {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.search-input {
  flex: 1;
  height: 72rpx;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  border-style: solid;
  border-color: #ddd;
  /* @mpx-else */
  border: 1rpx solid #ddd;
  /* @mpx-endif */
  border-radius: 8rpx;
  padding-left: 20rpx;
  padding-right: 20rpx;
  font-size: 28rpx;
}

.search-btn {
  width: 120rpx;
  height: 72rpx;
  margin-left: 16rpx;
  background-color: #ff6b00;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-btn-hover {
  opacity: 0.7;
}

.btn-text {
  color: white;
  font-size: 28rpx;
}

.filter-bar {
  display: flex;
  flex-direction: row;
  margin-bottom: 20rpx;
}

.filter-item {
  padding: 12rpx 24rpx;
  margin-right: 16rpx;
  border-radius: 24rpx;
  background-color: #f5f5f5;
}

.filter-item-hover {
  opacity: 0.7;
}

.filter-active {
  background-color: #ff6b00;
  color: white;
}

.product-scroll {
  flex: 1;
}

.product-card {
  display: flex;
  flex-direction: row;
  padding: 20rpx;
  margin-bottom: 16rpx;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  border-style: solid;
  border-color: #eee;
  /* @mpx-else */
  border: 1rpx solid #eee;
  /* @mpx-endif */
  border-radius: 12rpx;
}

.product-card-hover {
  background-color: #fafafa;
}

.product-img {
  width: 200rpx;
  height: 200rpx;
  border-radius: 8rpx;
}

.product-info {
  margin-left: 20rpx;
  flex: 1;
}

/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* @mpx-else */
.product-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}
/* @mpx-endif */

.product-tags {
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 8rpx;
}

.tag {
  font-size: 20rpx;
  color: #ff6b00;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-width: hairlineWidth;
  border-style: solid;
  border-color: #ff6b00;
  /* @mpx-else */
  border: 1rpx solid #ff6b00;
  /* @mpx-endif */
  border-radius: 4rpx;
  padding: 2rpx 8rpx;
  margin-right: 8rpx;
  margin-bottom: 4rpx;
}

.price-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
  margin-top: 12rpx;
}

.product-price {
  font-size: 36rpx;
  font-weight: bold;
  color: #ff4757;
}

.product-sales {
  font-size: 22rpx;
  color: #999;
}

.exposure-tracker {
  padding: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}
</style>

<script name="json">
const isRN = __mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony'

module.exports = {
  navigationBarTitleText: '商品列表',
  disableScroll: isRN
}
</script>
