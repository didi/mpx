<template>
  <scroll-view
    class="list"
    scroll-y
    refresher-enabled
    refresher-triggered="{{refreshing}}"
    bindrefresherrefresh="onRefresh"
    bindscrolltolower="onScrollToLower"
  >
    <view class="list-header">
      <text class="list-header-title">列表标题</text>
    </view>
    <view
      wx:for="{{items}}"
      wx:key="id"
      class="list-item"
      wx:class="{{ {'list-item-active': currentId === item.id, 'list-item-first': index === 0} }}"
      hover-class="list-item-hover"
      hover-stay-time="{{100}}"
      data-id="{{item.id}}"
      bindtap="goDetail"
    >
      <text
        class="item-content"
        numberOfLines@ios|android|harmony="{{1}}"
      >{{item.text}}</text>
    </view>
    <view wx:if="{{loading}}" class="loading">加载中...</view>
  </scroll-view>
</template>

<script>
import { createPage } from '@mpxjs/core'
import mpx from '@mpxjs/core'

createPage({
  data: {
    items: [],
    loading: false,
    currentId: null,
    refreshing: false
  },
  onLoad () {
    this.fetchList()
  },
  onPullDownRefresh () {
    this.fetchList()
  },
  onReachBottom () {
    this.loadMore()
  },
  methods: {
    fetchList () {
      this.loading = true
      mpx.request({
        url: '/api/list',
        success: (res) => {
          this.items = res.data
          this.loading = false
          this.refreshing = false
        }
      })
    },
    loadMore () {},
    goDetail (e) {
      const id = e.currentTarget.dataset.id
      this.currentId = id
      mpx.navigateTo({ url: '/pages/detail?id=' + id })
    },
    onRefresh () {
      this.refreshing = true
      this.fetchList()
    },
    onScrollToLower () {
      this.loadMore()
    }
  }
})
</script>

<style lang="less">
.list {
  padding: 24rpx;
  flex: 1;
}

.list-header-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
}

.list-item {
  padding: 20rpx;
  border-bottom-style: solid;
  border-bottom-color: #eee;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-bottom-width: hairlineWidth;
  /* @mpx-else */
  border-bottom-width: 1rpx;
  /* @mpx-endif */
}

.list-item-first {
  border-top-style: solid;
  border-top-color: #eee;
  /* @mpx-if (__mpx_mode__ === 'ios' || __mpx_mode__ === 'android' || __mpx_mode__ === 'harmony') */
  border-top-width: hairlineWidth;
  /* @mpx-else */
  border-top-width: 1rpx;
  /* @mpx-endif */
}

.list-item-hover {
  background-color: #f5f5f5;
}

.item-content {
  font-size: 28rpx;
  color: #666;
}

/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
.item-content {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}
/* @mpx-endif */

.list-item-active {
  background-color: #e8f0ff;
}

.loading {
  text-align: center;
  padding: 20rpx;
}
</style>
