<template>
  <view class="card-list">
    <view
      class="card"
      wx:for="{{cards}}"
      wx:key="id"
      bindtap="onTap"
      hover-class="card-hover"
      hover-stay-time="{{100}}"
      wx:class="{{ { 'card-gap': index > 0 } }}"
    >
      <view class="card-decorator"></view>
      <view class="card-body">
        <text
          class="card-title"
          numberOfLines@ios|android|harmony="{{1}}"
        >{{item.title}}</text>
        <view
          class="card-content"
          numberOfLines@ios|android|harmony="{{3}}"
        >{{item.content}}</view>
      </view>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    cards: { type: Array, value: [] }
  },
  methods: {
    onTap () {
      this.triggerEvent('cardtap')
    }
  }
})
</script>

