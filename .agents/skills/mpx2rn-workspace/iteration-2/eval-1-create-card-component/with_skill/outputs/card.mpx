<template>
  <view
    class="card"
    wx:class="{{ {cardSelected: selected} }}"
    hover-class="card-hover"
    hover-stay-time="{{100}}"
    bindtap="handleTap"
  >
    <view class="card-header">
      <image class="card-avatar" src="{{avatar}}" mode="aspectFill"></image>
      <view class="card-info">
        <text
          class="card-title"
          numberOfLines@ios|android|harmony="{{1}}"
        >{{title}}</text>
        <text
          class="card-desc"
          numberOfLines@ios|android|harmony="{{2}}"
        >{{desc}}</text>
      </view>
    </view>
  </view>
</template>

<script setup>
  import { toRefs } from '@mpxjs/core'

  const props = defineProps({
    title: {
      type: String,
      value: ''
    },
    desc: {
      type: String,
      value: ''
    },
    avatar: {
      type: String,
      value: ''
    },
    selected: {
      type: Boolean,
      value: false
    }
  })

  const { title, desc, avatar, selected } = toRefs(props)

  const context = useContext()

  function handleTap() {
    context.triggerEvent('tap')
  }

  defineExpose({
    title,
    desc,
    avatar,
    selected,
    handleTap
  })
</script>

<style>
  .card {
    flex-direction: row;
    padding: 24rpx;
    background-color: #ffffff;
    border-radius: 16rpx;
    border-width: 2rpx;
    border-style: solid;
    border-color: #e8e8e8;
  }

  .cardSelected {
    border-color: #1677ff;
  }

  .card-hover {
    opacity: 0.7;
    background-color: #f5f5f5;
  }

  .card-header {
    flex-direction: row;
    align-items: flex-start;
    flex: 1;
  }

  .card-avatar {
    width: 80rpx;
    height: 80rpx;
    border-radius: 40rpx;
    margin-right: 20rpx;
    flex-shrink: 0;
  }

  .card-info {
    flex: 1;
    flex-direction: column;
    justify-content: center;
  }

  .card-title {
    font-size: 32rpx;
    font-weight: bold;
    color: #333333;
  }

  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  .card-title {
    white-space: nowrap;
    text-overflow: ellipsis;
    overflow: hidden;
  }
  /* @mpx-endif */

  .card-desc {
    font-size: 26rpx;
    color: #999999;
    margin-top: 8rpx;
    line-height: 36rpx;
  }

  /* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
  .card-desc {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  /* @mpx-endif */
</style>

<script type="application/json">
  {
    "component": true
  }
</script>
