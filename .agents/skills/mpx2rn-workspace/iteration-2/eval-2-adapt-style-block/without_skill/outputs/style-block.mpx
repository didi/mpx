<template>
  <view class="card-list">
    <view class="card" wx:for="{{cards}}" wx:key="id" bindtap="onTap">
      <!-- 用真实 view 替代 ::before 伪元素，仅 RN 平台渲染 -->
      <view wx:if="{{__mpx_mode__ === 'ios' || __mpx_mode__ === 'android'}}" class="card-before"></view>
      <text class="card-title" wx:if="{{__mpx_mode__ === 'ios' || __mpx_mode__ === 'android'}}" numberOfLines="1">{{item.title}}</text>
      <text class="card-title" wx:else>{{item.title}}</text>
      <view class="card-content" wx:if="{{__mpx_mode__ === 'ios' || __mpx_mode__ === 'android'}}" numberOfLines="3">{{item.content}}</view>
      <view class="card-content" wx:else>{{item.content}}</view>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    cards: { type: Array, value: [] }
  },
  methods: {
    onTap () {
      this.triggerEvent('cardtap')
    }
  }
})
</script>

<!-- 默认样式：小程序/Web 平台 -->
<style lang="less">
.card-list {
  padding: 16rpx;
  .card {
    position: relative;
    padding: 20rpx;
    background: white;
    border: 1rpx solid #ddd;
    border-radius: 8rpx;
    display: grid;
    grid-template-columns: 1fr 1fr;
    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 4rpx;
      height: 100%;
      background: blue;
    }
    &:active {
      opacity: 0.8;
    }
    .card-title {
      font-size: 32rpx;
      font-weight: 600;
      color: #333;
      text-overflow: ellipsis;
      white-space: nowrap;
      overflow: hidden;
    }
    .card-content {
      margin-top: 12rpx;
      font-size: 28rpx;
      color: #666;
      word-break: break-all;
      line-clamp: 3;
    }
  }
  .card + .card {
    margin-top: 16rpx;
  }
}
</style>

<!-- RN 平台样式：扁平化选择器，移除不支持的属性 -->
<style lang="css" mode="ios">
.card-list {
  padding: 16rpx;
}
.card {
  position: relative;
  padding: 20rpx;
  padding-left: 24rpx;
  background-color: white;
  border-width: 1rpx;
  border-style: solid;
  border-color: #ddd;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  margin-bottom: 16rpx;
}
.card-before {
  position: absolute;
  top: 0;
  left: 0;
  width: 4rpx;
  height: 100%;
  background-color: blue;
}
.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}
.card-content {
  margin-top: 12rpx;
  font-size: 28rpx;
  color: #666;
}
</style>
