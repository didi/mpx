</template>
<style>
/* 替换 grid 和 float 为 flex 布局 */
.layout {
  display: flex;
  flex-direction: row;
}
.left {
  /* rem 替换为 rpx */
  width: 100rpx; /* 假设 1rem = 10rpx，根据实际情况调整 */
}
.right {
  width: 50%;
}
/* @mpx-if (__mpx_mode__ === 'wx' || __mpx_mode__ === 'ali' || __mpx_mode__ === 'web') */
.right-text {
  white-space: nowrap;
  text-overflow: ellipsis;
