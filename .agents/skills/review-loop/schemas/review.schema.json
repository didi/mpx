{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ReviewLoopReview",
  "type": "object",
  "required": ["round", "status", "summary", "findings"],
  "additionalProperties": false,
  "properties": {
    "round": {
      "type": "integer",
      "minimum": 1
    },
    "status": {
      "type": "string",
      "enum": ["approved", "changes_requested"]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "category", "target", "comment", "suggestion"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "severity": {
            "type": "string",
            "enum": ["critical", "major", "minor", "nit"]
          },
          "category": {
            "type": "string",
            "minLength": 1
          },
          "target": {
            "type": "string",
            "minLength": 1
          },
          "comment": {
            "type": "string",
            "minLength": 1
          },
          "suggestion": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
