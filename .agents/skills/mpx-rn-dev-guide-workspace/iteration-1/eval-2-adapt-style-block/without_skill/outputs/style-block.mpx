<template>
  <view class="card-list">
    <view
      class="card {{index > 0 ? 'card-spacing' : ''}}"
      wx:for="{{cards}}"
      wx:key="id"
      bindtap="onTap"
      hover-class="card-hover"
    >
      <view class="card-bar"></view>
      <text class="card-title" numberOfLines="{{1}}">{{item.title}}</text>
      <text class="card-content" numberOfLines="{{3}}">{{item.content}}</text>
    </view>
  </view>
</template>

<script>
import { createComponent } from '@mpxjs/core'

createComponent({
  properties: {
    cards: { type: Array, value: [] }
  },
  methods: {
    onTap () {
      this.triggerEvent('cardtap')
    }
  }
})
</script>

