<template>
  <scroll-view class="container" scroll-y="{{ true }}" testID="visualRegressionPage">
    <view class="header">
      <view class="header-content">
        <view class="back-btn" bindtap="goBack" testID="visualBackBtn">
          <text class="back-text">←</text>
        </view>
        <view class="header-copy">
          <text class="title" testID="visualTitle">视觉回归检测示例</text>
          <text class="subtitle">对比 3 类异常场景，观察 Midscene 是否能识别差异</text>
        </view>
      </view>
    </view>

    <view class="panel-card toolbar-card" testID="visualToolbar">
      <view class="toolbar-row">
        <text class="toolbar-label">当前场景</text>
        <view class="mode-chip {{ layoutMode === 'baseline' ? 'mode-chip-baseline' : 'mode-chip-warning' }}">
          <text class="mode-chip-text" testID="visualLayoutModeLabel">{{ currentModeLabel }}</text>
        </view>
      </view>

      <view class="mode-grid">
        <view
          class="mode-btn {{ layoutMode === 'baseline' ? 'mode-btn-active' : '' }}"
          bindtap="setLayoutMode"
          data-mode="baseline"
          testID="visualMode-baseline"
        >
          <text class="mode-btn-text {{ layoutMode === 'baseline' ? 'mode-btn-text-active' : '' }}">正确布局</text>
        </view>
        <view
          class="mode-btn mode-btn-warning {{ layoutMode === 'layout' ? 'mode-btn-active-warning' : '' }}"
          bindtap="setLayoutMode"
          data-mode="layout"
          testID="visualMode-layout"
        >
          <text class="mode-btn-text {{ layoutMode === 'layout' ? 'mode-btn-text-active' : '' }}">左右布局变化</text>
        </view>
        <view
          class="mode-btn mode-btn-secondary {{ layoutMode === 'spacing' ? 'mode-btn-active-secondary' : '' }}"
          bindtap="setLayoutMode"
          data-mode="spacing"
          testID="visualMode-spacing"
        >
          <text class="mode-btn-text {{ layoutMode === 'spacing' ? 'mode-btn-text-active' : '' }}">间距变化</text>
        </view>
        <view
          class="mode-btn mode-btn-muted {{ layoutMode === 'pixel' ? 'mode-btn-active-muted' : '' }}"
          bindtap="setLayoutMode"
          data-mode="pixel"
          testID="visualMode-pixel"
        >
          <text class="mode-btn-text {{ layoutMode === 'pixel' ? 'mode-btn-text-active' : '' }}">1 像素变化</text>
        </view>
      </view>

      <text class="toolbar-hint" testID="visualHint">{{ currentHint }}</text>
    </view>

    <view class="panel-card preview-card" testID="visualPreviewCard">
      <view class="preview-header">
        <text class="section-title">待检测主区域</text>
        <text class="preview-header-note">测试只比对下面这块单屏主区域</text>
      </view>

      <view
        class="story-board {{ layoutMode === 'spacing' ? 'story-board-spacing' : '' }}"
        testID="visualStoryBoard"
      >
        <view class="board-topline {{ layoutMode === 'spacing' ? 'board-topline-spacing' : '' }}">
          <text class="eyebrow">春季发布</text>
          <view class="badge-group">
            <view class="badge badge-dark">
              <text class="badge-text">网格检测</text>
            </view>
            <view class="badge badge-light">
              <text class="badge-text badge-text-light">间距观察</text>
            </view>
          </view>
        </view>

        <view class="board-grid">
          <view
            class="hero-card {{ layoutMode === 'spacing' ? 'hero-card-spacing' : '' }} {{ layoutMode === 'pixel' ? 'hero-card-pixel' : '' }}"
            testID="visualHeroCard"
          >
            <text class="hero-kicker">设计系统</text>
            <text class="hero-title">布局基线海报</text>
            <text class="hero-desc">
              标准状态下，主卡片固定在上方，下方两张信息卡横向并排，按钮与底部信息保持稳定节奏。
            </text>

            <view class="hero-footer {{ layoutMode === 'layout' ? 'hero-footer-layout' : '' }} {{ layoutMode === 'spacing' ? 'hero-footer-spacing' : '' }}">
              <view class="pill pill-primary">
                <text class="pill-text pill-text-primary">准备发布</text>
              </view>
              <view class="cta-btn">
                <text class="cta-text">查看基线</text>
              </view>
            </view>
          </view>

          <view
            class="side-column {{ layoutMode === 'layout' ? 'side-column-layout' : '' }} {{ layoutMode === 'spacing' ? 'side-column-spacing' : '' }}"
            testID="visualSideColumn"
          >
            <view
              class="mini-card mini-card-teal {{ layoutMode === 'spacing' ? 'mini-card-spacing' : '' }}"
              testID="visualMiniCard-progress"
            >
              <text class="mini-label">进度</text>
              <text class="mini-value">84%</text>
            </view>
            <view
              class="mini-card mini-card-light {{ layoutMode === 'spacing' ? 'mini-card-spacing mini-card-light-spacing' : '' }}"
              testID="visualMiniCard-review"
            >
              <text class="mini-label">检查项</text>
              <text class="mini-note">间距 / 顺序 / 对齐</text>
            </view>
          </view>
        </view>

        <view class="board-footer {{ layoutMode === 'spacing' ? 'board-footer-spacing' : '' }}">
          <view class="tag-list">
            <text
              wx:for="{{ tags }}"
              wx:key="*this"
              class="tag-item"
            >{{ item }}</text>
          </view>
        </view>
      </view>
    </view>
  </scroll-view>
</template>

<script setup>
import mpx, { computed, ref } from '@mpxjs/core'

const layoutMode = ref('baseline')
const tags = ['主卡置顶', '双卡横排', '基线对齐']

const modeLabelMap = {
  baseline: '正确布局',
  layout: '左右布局变化',
  spacing: '间距变化',
  pixel: '1 像素变化'
}

const hintMap = {
  baseline: '先保存这张基线图，后面的对比都以它为准。',
  layout: '改变卡片左右次序和按钮方向，观察 Midscene 是否能识别结构变化。',
  spacing: '保持结构不变，只改上下左右留白，观察 Midscene 是否能识别间距异常。',
  pixel: '只在主卡片上增加 1 像素描边，观察 Midscene 对极小像素变化的敏感度。'
}

const currentModeLabel = computed(() => modeLabelMap[layoutMode.value] || modeLabelMap.baseline)
const currentHint = computed(() => hintMap[layoutMode.value] || hintMap.baseline)

function setLayoutMode(e) {
  const nextMode = e.currentTarget.dataset.mode
  layoutMode.value = modeLabelMap[nextMode] ? nextMode : 'baseline'
}

function goBack() {
  mpx.navigateBack()
}

defineExpose({
  layoutMode,
  tags,
  currentModeLabel,
  currentHint,
  setLayoutMode,
  goBack
})
</script>

