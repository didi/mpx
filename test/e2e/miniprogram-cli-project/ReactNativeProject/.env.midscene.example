# Required Midscene model settings
# Fill these with your own OpenAI-compatible model service.
MIDSCENE_MODEL_NAME=your-model-name
MIDSCENE_MODEL_FAMILY=your-model-family
MIDSCENE_MODEL_API_KEY=your-api-key
MIDSCENE_MODEL_BASE_URL=https://your-openai-compatible-endpoint/v1

# Optional Android settings
MIDSCENE_ANDROID_DEVICE_ID=
MIDSCENE_ANDROID_APP_ID=com.reactnativeproject
MIDSCENE_ADB_PATH=

# Optional Midscene runtime settings
MIDSCENE_PREFERRED_LANGUAGE=zh-CN
MIDSCENE_RUN_DIR=./artifacts/midscene
