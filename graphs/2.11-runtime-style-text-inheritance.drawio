        <mxCell id="edge-w3c-final" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#d6b656;strokeWidth=2;endArrow=block;html=1;" edge="1" parent="1" source="step3b" target="w3c-2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge-perf-final" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#b85450;strokeWidth=2;endArrow=block;html=1;" edge="1" parent="1" source="w3c-2" target="perf-final">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="context-line-1" value="TextPassThroughContext 覆盖子树" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;endArrow=none;html=1;fontSize=12;fontColor=#6b4c7a;" edge="1" parent="1" source="ctx1" target="ctx-pass">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="context-line-2" value="继承样式进入 text" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;endArrow=block;html=1;fontSize=12;fontColor=#6b4c7a;" edge="1" parent="1" source="ctx-pass" target="step3a">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="1065" y="502"/>
              <mxPoint x="590" y="502"/>
            </Array>
          </mxGeometry>
        </mxCell>
        <mxCell id="context-line-3" value="同一份继承上下文" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#9673a6;strokeWidth=2;dashed=1;endArrow=block;html=1;fontSize=12;fontColor=#6b4c7a;" edge="1" parent="1" source="ctx-pass" target="step3b">
